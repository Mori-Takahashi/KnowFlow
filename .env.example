# Debug output (see https://www.npmjs.com/package/debug)
# Use knowflow:* to enable all modules, or comma-separated namespaces.
DEBUG=knowflow:*

# HTTP server
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# SQLite database file (relative to project root)
DATABASE_URL=./data/knowflow.sqlite

# Verzeichnis für heruntergeladene Jira-Anhänge (relativ oder absolut)
ATTACHMENTS_DIR=./data/attachments
# Maximale Größe je Anhang in Bytes (Standard 20 MiB). Größere Anhänge werden
# nicht geladen, sondern als übersprungen vermerkt.
ATTACHMENT_MAX_BYTES=20971520

# ---------------------------------------------------------------------------
# Admin-Dashboard & Secrets
# ---------------------------------------------------------------------------
# Master-Key zum Verschlüsseln der in der DB gespeicherten Tokens (Jira/OpenWebUI/
# Webhook-Secret). PFLICHT. Beliebige zufällige Zeichenkette (>= 16 Zeichen).
# WICHTIG: Wird dieser Key geändert, sind bereits verschlüsselte Tokens nicht
# mehr lesbar und müssen im Dashboard neu eingegeben werden.
SETTINGS_ENCRYPTION_KEY=bitte-zufaelligen-langen-key-setzen

# Signier-Secret für die Admin-Session-Cookies. Optional — fällt auf
# SETTINGS_ENCRYPTION_KEY zurück, wenn nicht gesetzt.
SESSION_SECRET=

# Initiales Admin-Passwort. Wird beim ERSTEN Start in die DB übernommen (gehasht)
# und schaltet den Login frei. Danach im Dashboard änderbar. OPTIONAL: Bleibt die
# Variable leer bzw. weg, startet beim ersten Aufruf des Dashboards der
# Setup-Assistent im Browser und führt Schritt für Schritt durch die
# Ersteinrichtung (Admin-Passwort, Jira-Verbindung, Wissensbasis).
ADMIN_PASSWORD=changeme

# ---------------------------------------------------------------------------
# Hinweis: Die folgenden Jira-/OpenWebUI-Werte werden nur beim ERSTEN Start als
# Startwerte (Seed) in die DB übernommen. Danach ist das Admin-Dashboard die
# Quelle der Wahrheit — Änderungen hier wirken nicht mehr ohne Reset der DB.
# ---------------------------------------------------------------------------

# Jira Cloud REST API credentials
JIRA_BASE_URL=https://your-workspace.atlassian.net
JIRA_EMAIL=your.user@example.com
JIRA_API_TOKEN=your-jira-api-token
# Comma-separated list of project keys that should be processed
JIRA_PROJECT_KEYS=KNOW,DOC,WIKI,HELP

# Jira status names that trigger the pipeline.
# JIRA_DONE_STATUS accepts a comma-separated list, so different Jira workflows
# (z.B. "erledigt, Fertig, Erledigt") können gleichzeitig getriggert werden.
# Vergleich erfolgt case-insensitive.
JIRA_DONE_STATUS=Done
JIRA_REWORK_STATUSES=Überarbeiten,Updaten

# Optional shared secret for Jira webhook signature validation
JIRA_WEBHOOK_SECRET=

# Verbose webhook debug mode. Wenn true, gibt der Bot pro eingehendem Jira-Webhook
# einen mehrzeiligen Block mit Headern, Body, extrahierten Werten und Routing-Entscheidung
# per console.log aus (unabhängig von der DEBUG-Variable).
WEBHOOK_DEBUG=false

# UI-Debug-Modus für Präsentationen. Wenn true, blendet die Web-UI ein
# Debug-Panel ein, mit dem man einen Ticket-Transfer künstlich auslösen kann
# (langsam, normal, schnell) und gezielt in einem Schritt abbrechen lassen kann,
# sowie einzelne Services (Jira, OpenWebUI, KnowFlow) als "nicht erreichbar"
# markieren kann. Greift auf KEINE echten Jira-/OpenWebUI-APIs zu.
# In Produktion immer false lassen.
UI_DEBUG=false

# Open WebUI integration
# Mode: 'dummy' (local mock, no external calls) or 'real' (HTTP calls against OPENWEBUI_URL)
OPENWEBUI_MODE=dummy

# ---------------------------------------------------------------------------
# VERALTET (Legacy): Single-Wissensbasis-Konfiguration
# ---------------------------------------------------------------------------
# Die folgenden drei Variablen stammen aus der Zeit, als KnowFlow nur EINE
# Open-WebUI-Wissensbasis kannte. Sie werden ausschließlich beim ERSTEN Start
# verwendet, um eine Standard-Wissensbasis ("Standard-Wissensbasis") zu seeden.
#
# Seit dem Multi-Wissensbasen-/MCP-Update werden beliebig viele Wissensbasen
# samt Token, Knowledge-ID und Routing-Regeln im Admin-Dashboard verwaltet
# (Tabs "Wissensbasen", "Routing-Regeln", "MCP-Verbindungen"). Für neue
# Setups können diese Variablen leer bleiben — trage die Wissensbasis dann
# einfach nach dem ersten Login im Dashboard ein.
OPENWEBUI_URL=https://chat.example.com
OPENWEBUI_TOKEN=
OPENWEBUI_KNOWLEDGE_ID=
